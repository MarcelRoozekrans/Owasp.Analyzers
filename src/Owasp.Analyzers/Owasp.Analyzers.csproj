<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <NoWarn>RS2008</NoWarn>
    <RootNamespace>Owasp.Analyzers</RootNamespace>
    <PackageId>Owasp.Analyzers</PackageId>
    <Description>Roslyn analyzers covering the OWASP Top 10 2021 for C#/.NET projects.</Description>
    <PackageTags>roslyn;analyzer;owasp;security</PackageTags>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <DevelopmentDependency>true</DevelopmentDependency>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Owasp.Analyzers.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- Bundle the analyzer assembly, MSBuild targets, icon, and readme into the NuGet package -->
  <ItemGroup>
    <None Include="build\Owasp.Analyzers.targets" Pack="true" PackagePath="build\" />
    <None Include="$(OutputPath)$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="..\..\assets\logo.png" Pack="true" PackagePath="\" />
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
